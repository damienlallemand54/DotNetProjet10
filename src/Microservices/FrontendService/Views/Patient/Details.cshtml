@model FrontendService.Models.PatientViewModel

@{
    ViewData["Title"] = "Détail patient";
}

<div class="container mt-4">
    <div class="card shadow">
        <div class="card-header bg-primary text-white">
            <h2 class="mb-0">Dossier patient — @Model.LastName @Model.FirstName</h2>
        </div>
        <div class="card-body">
            <dl class="row">
                <dt class="col-sm-3">Nom</dt>
                <dd class="col-sm-9">@Model.LastName</dd>

                <dt class="col-sm-3">Prénom</dt>
                <dd class="col-sm-9">@Model.FirstName</dd>

                <dt class="col-sm-3">Date de naissance</dt>
                <dd class="col-sm-9">@Model.BirthDate.ToString("dd/MM/yyyy")</dd>

                <dt class="col-sm-3">Âge</dt>
                <dd class="col-sm-9">@Model.Age ans</dd>

                <dt class="col-sm-3">Genre</dt>
                <dd class="col-sm-9">@Model.Gender</dd>

                <dt class="col-sm-3">Adresse</dt>
                <dd class="col-sm-9">@(Model.Address ?? "Non renseignée")</dd>

                <dt class="col-sm-3">Téléphone</dt>
                <dd class="col-sm-9">@(Model.PhoneNumber ?? "Non renseigné")</dd>
            </dl>
        </div>
        <div class="card-footer">
            <a asp-action="Index" class="btn btn-secondary">Retour à la liste</a>
        </div>
    </div>
</div>

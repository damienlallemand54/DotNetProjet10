@model List<FrontendService.Models.PatientViewModel>

@{
    ViewData["Title"] = "Liste des patients";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h1>Liste des patients</h1>
        <a asp-action="Create" class="btn btn-success">+ Ajouter un patient</a>
    </div>

    <div class="table-responsive">
        <table class="table table-striped table-hover">
            <thead class="table-dark">
                <tr>
                    <th>Nom</th>
                    <th>Prénom</th>
                    <th>Date de naissance</th>
                    <th>Genre</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var patient in Model)
                {
                    <tr>
                        <td>@patient.LastName</td>
                        <td>@patient.FirstName</td>
                        <td>@patient.BirthDate.ToString("dd/MM/yyyy")</td>
                        <td>@patient.Gender</td>
                        <td>
                            <a asp-action="Details" asp-route-id="@patient.Id" class="btn btn-sm btn-outline-primary">Détail</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>